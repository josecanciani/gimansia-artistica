{
    "compilerOptions": {
        "checkJs": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "paths": {
            "/js/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*.js",
        "htdocs/**/*.js"
    ],
    "exclude": [
        "src/lib/**",
        "node_modules"
    ]
}
