{
    "name": "gimnasia-artistica",
    "version": "1.0.0",
    "description": "Gimnasia Artistica Website",
    "type": "module",
    "scripts": {
        "test": "npm run lint && npm run format:check && npm run test:node",
        "test:node": "node --test test/*.test.js test/**/*.test.js",
        "test:browser": "playwright test",
        "test:all": "npm run test && npm run test:browser",
        "start": "node server.js",
        "lint": "oxlint htdocs/ src/ && npm run jsdoc-check && npm run typecheck && npm run html-check",
        "format": "oxfmt --write 'src/**/*.{js,css}' 'htdocs/**/*.{js,css}' && npm run format:html",
        "format:check": "oxfmt --check 'src/**/*.{js,css}' 'htdocs/**/*.{js,css}'",
        "format:html": "html-beautify -r 'htdocs/**/*.html'",
        "html-check": "html-validate 'htdocs/**/*.html'",
        "jsdoc-check": "eslint htdocs/ src/",
        "typecheck": "tsc -p jsconfig.json --noEmit"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "eslint": "^10.1.0",
        "eslint-plugin-jsdoc": "^62.8.1",
        "express": "^5.2.1",
        "html-validate": "^10.11.2",
        "js-beautify": "^1.15.4",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@fusewire/client": "github:josecanciani/fusewire#release/1.0.0"
    }
}
