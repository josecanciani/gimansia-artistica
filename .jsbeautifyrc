{
    "html": {
        "indent_size": 4,
        "indent_char": " ",
        "end_with_newline": true,
        "preserve_newlines": true,
        "max_preserve_newlines": 2,
        "wrap_line_length": 0,
        "wrap_attributes": "preserve-aligned",
        "templating": ["none"],
        "indent_inner_html": false,
        "extra_liners": []
    }
}
